generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ProductStatus {
  ACTIVE
  DRAFT
}

enum OrderStatus {
  PENDING_PAYMENT
  PROOF_SENT
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  category    String
  description String
  price       Int
  oldPrice    Int?
  coverImage  String?
  videoUrl    String?
  fileUrl     String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orders      Order[]
}

model Order {
  id          String      @id @default(cuid())
  reference   String      @unique
  userId      String
  productId   String
  pricePaid   Int
  method      String?
  proofImage  String?
  status      OrderStatus @default(PENDING_PAYMENT)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
}

model PaymentSetting {
  id          String   @id @default(cuid())
  mpesaName   String?
  mpesaNumber String?
  emolaName   String?
  emolaNumber String?
  bankName    String?
  bankAccount String?
  bankHolder  String?
  whatsapp    String?
  updatedAt   DateTime @updatedAt
}
